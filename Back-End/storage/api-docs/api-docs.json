        "/api/v1/notes/{uuid}/collaborators": {
            "post": {
                "tags": [
                    "Collaborators"
                ],
                "operationId": "e8e5aebce0d105cadd4463f62103559a",
                "parameters": [
                    {
                        "name": "uuid",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "subject_type",
                                    "subject_id",
                                    "permission"
                                ],
                                "properties": {
                                    "subject_type": {
                                        "type": "string",
                                        "enum": [
                                            "user",
                                            "role",
                                            "department"
                                        ]
                                    },
                                    "subject_id": {
                                        "type": "integer"
                                    },
                                    "permission": {
                                        "type": "string",
                                        "enum": [
                                            "viewer",
                                            "editor",
                                            "commenter"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Collaborator berhasil ditambahkan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
